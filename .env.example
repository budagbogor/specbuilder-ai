# SpecBuilder AI Environment Variables
# Copy this file to .env and fill in the values

# ── Database ──────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── OpenAI ────────────────────────────────────────────
# Required: Your OpenAI API key
OPENAI_API_KEY=""

# Optional: Model to use (default: gpt-5.2)
# OPENAI_MODEL="gpt-5.2"

# Optional: Request timeout in milliseconds (default: 45000)
# OPENAI_TIMEOUT_MS=45000

# Optional: Max retries for failed requests (default: 2)
# OPENAI_MAX_RETRIES=2

# ── Rate Limiting ─────────────────────────────────────
# Optional: Max analyze requests per window (default: 12)
# AI_ANALYZE_RATE_LIMIT=12

# Optional: Analyze rate limit window in ms (default: 60000)
# AI_ANALYZE_RATE_LIMIT_WINDOW_MS=60000

# Optional: Max generate requests per window (default: 6)
# AI_GENERATE_RATE_LIMIT=6

# Optional: Generate rate limit window in ms (default: 60000)
# AI_GENERATE_RATE_LIMIT_WINDOW_MS=60000
